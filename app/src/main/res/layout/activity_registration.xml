<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Gradient header — adım göstergesi -->
    <LinearLayout
        android:id="@+id/regHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💙  Hesap Yönetimi"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Adım noktaları -->
        <LinearLayout
            android:id="@+id/stepDotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <View android:id="@+id/dot1" android:layout_width="28dp" android:layout_height="6dp" android:layout_margin="4dp" android:background="#FFFFFF" />
            <View android:id="@+id/dot2" android:layout_width="28dp" android:layout_height="6dp" android:layout_margin="4dp" android:background="#55FFFFFF" />
            <View android:id="@+id/dot3" android:layout_width="28dp" android:layout_height="6dp" android:layout_margin="4dp" android:background="#55FFFFFF" />
            <View android:id="@+id/dot4" android:layout_width="28dp" android:layout_height="6dp" android:layout_margin="4dp" android:background="#55FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Hoş Geldiniz"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- İçerik alanı -->
    <ScrollView
        android:id="@+id/regScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ADIM 1: Hoş geldiniz -->
            <LinearLayout
                android:id="@+id/step1Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💎"
                    android:textSize="64sp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Finansal özgürlüğünüz\nbir dokunuş uzağınızda."
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Gelir ve giderlerinizi takip edin,\nbütçenizi yönetin, hedeflerinize ulaşın."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ADIM 2: İsim + Avatar -->
            <LinearLayout
                android:id="@+id/step2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sizi nasıl tanıyalım? 👋"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adınız ve bir avatar seçin"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/green_light"
                    android:hint="Adınız Soyadınız">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLength="30" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avatar seçin:"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp" />

                <!-- Seçili avatar göstergesi -->
                <TextView
                    android:id="@+id/tvSelectedAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="32sp"
                    android:background="@drawable/bg_profile_avatar"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:id="@+id/avatarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="6" />
            </LinearLayout>

            <!-- ADIM 3: Güvenlik sorusu -->
            <LinearLayout
                android:id="@+id/step3Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Güvenlik Sorusu 🔐"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PIN'inizi unuttuğunuzda bu soruyla doğrulama yapabilirsiniz."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp" />

                <!-- Soru seçimi (4 kart) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bir soru seçin:"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <RadioGroup
                    android:id="@+id/radioQuestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <RadioButton android:id="@+id/rq0" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="İlk evcil hayvanınızın adı nedir?" android:textColor="@color/text_primary" android:layout_marginBottom="6dp"/>
                    <RadioButton android:id="@+id/rq1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Annenizin kız soyadı nedir?" android:textColor="@color/text_primary" android:layout_marginBottom="6dp"/>
                    <RadioButton android:id="@+id/rq2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Doğduğunuz şehir neresidir?" android:textColor="@color/text_primary" android:layout_marginBottom="6dp"/>
                    <RadioButton android:id="@+id/rq3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="En sevdiğiniz film nedir?" android:textColor="@color/text_primary"/>
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAnswer"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/green_light"
                    android:hint="Cevabınız">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:maxLength="50" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- ADIM 4: PIN oluştur -->
            <LinearLayout
                android:id="@+id/step4Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Güvenli PIN Belirle 🔑"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 haneli bir PIN kodu oluşturun"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="32dp" />

                <!-- PIN noktaları -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="32dp">
                    <View android:id="@+id/pin_dot1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
                    <View android:id="@+id/pin_dot2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
                    <View android:id="@+id/pin_dot3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
                    <View android:id="@+id/pin_dot4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
                </LinearLayout>

                <!-- Numpad -->
                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0,1,2">
                    <TableRow android:layout_marginBottom="10dp">
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn1" android:text="1"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn2" android:text="2"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn3" android:text="3"/>
                    </TableRow>
                    <TableRow android:layout_marginBottom="10dp">
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn4" android:text="4"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn5" android:text="5"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn6" android:text="6"/>
                    </TableRow>
                    <TableRow android:layout_marginBottom="10dp">
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn7" android:text="7"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn8" android:text="8"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn9" android:text="9"/>
                    </TableRow>
                    <TableRow>
                        <View android:layout_width="0dp" android:layout_height="0dp"/>
                        <Button style="@style/PinButtonStyle" android:id="@+id/reg_btn0" android:text="0"/>
                        <ImageButton
                            style="@style/PinButtonStyle"
                            android:id="@+id/reg_btn_del"
                            android:src="@android:drawable/ic_input_delete"
                            app:tint="@color/ana_mavi" />
                    </TableRow>
                </TableLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Alt buton satırı -->
    <LinearLayout
        android:id="@+id/bottomButtonBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="← Geri"
            android:visibility="gone"
            app:strokeColor="@color/green_light" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/green_primary"
            android:text="Başlayalım →"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
