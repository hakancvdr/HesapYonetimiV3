<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- STICKY HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/aylik_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_aylik_baslik"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aylık Analiz"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Özet kartları -->
        <LinearLayout
            android:id="@+id/ozet_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_aylik_baslik">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gelir" android:textSize="12sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_toplam_gelir"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ₺" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gider" android:textSize="12sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_toplam_gider"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ₺" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Net" android:textSize="12sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_net"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ₺" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Tarih + hızlı butonlar — tek satır -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView android:id="@+id/btn_donem_1a"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:paddingStart="9dp" android:paddingEnd="9dp"
            android:gravity="center" android:text="1A"
            android:textSize="12sp" android:textColor="@color/green_primary"
            android:background="@drawable/kategori_item_selected_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_donem_3a"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:paddingStart="9dp" android:paddingEnd="9dp"
            android:gravity="center" android:text="Önceki"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:background="@drawable/kategori_item_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_donem_6a"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:paddingStart="9dp" android:paddingEnd="9dp"
            android:gravity="center" android:text="3A"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:background="@drawable/kategori_item_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_donem_tumu"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:paddingStart="9dp" android:paddingEnd="9dp"
            android:gravity="center" android:text="6A"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:background="@drawable/kategori_item_bg"
            android:layout_marginEnd="6dp"
            android:clickable="true" android:focusable="true"/>

        <View android:layout_width="1dp" android:layout_height="22dp"
            android:background="#DDDDDD" android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/tv_baslangic_tarih"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/tarih_chip_bg"
            android:layout_marginEnd="3dp"
            android:clickable="true" android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="→" android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="3dp"/>

        <TextView android:id="@+id/tv_bitis_tarih"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/tarih_chip_bg"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- SCROLL -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- İstatistik kartları — kompakt, 3'lü -->
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="İşlem" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tv_islem_sayisi"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="18sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Günlük ort." android:textSize="12sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tv_gunluk_ort"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="18sp" android:textStyle="bold"
                                android:textColor="@color/expense_red" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Öneri metni -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_oneri_emoji"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="16sp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/tv_oneri_metin"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kategoriler -->
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategoriler"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_kategoriler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="80dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
