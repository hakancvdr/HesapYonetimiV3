<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/aylik_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_aylik_baslik"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_ay_ozet_line"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/ozet_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_ay_ozet_line">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/card_background" android:padding="10dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gelir" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tv_toplam_gelir" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 ₺" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="@color/income_green" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/card_background" android:padding="10dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gider" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tv_toplam_gider" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 ₺" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="@color/expense_red" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/card_background" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Net" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tv_net" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 ₺" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══ TAB SATIRI ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/tabTimeline"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/kategori_item_selected_bg"
            android:gravity="center"
            android:text="📋  İşlem Geçmişi"
            android:textColor="@color/green_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabCalendar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/kategori_item_bg"
            android:gravity="center"
            android:text="📅  Takvim"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabKategori"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/kategori_item_bg"
            android:gravity="center"
            android:text="📊  Kategori"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ═══ TAB İÇERİKLERİ ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── TAB 1: TAKVİM ─────────────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/tabCalendarContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Ay navigasyonu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <ImageButton
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/kategori_item_bg"
                        android:src="@drawable/ic_chevron_left"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvCalendarMonth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Nisan 2025"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnNextMonth"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/kategori_item_bg"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_primary" />
                </LinearLayout>

                <!-- Gün başlıkları: Pt Sa Ça Pe Cu Ct Pz -->
                <LinearLayout
                    android:id="@+id/dayHeaderRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Pt" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sa" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Ça" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Pe" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Cu" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Ct" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Pz" android:textSize="11sp" android:textColor="#EF5350"/>
                </LinearLayout>

                <!-- Takvim hücreleri (programatik doldurulacak) -->
                <GridLayout
                    android:id="@+id/calendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:layout_marginBottom="16dp" />

                <!-- Seçilen gün işlemleri -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/selectedDayCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvSelectedDayTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSelectedDayTx"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="80dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── TAB 2: TİMELİNE ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/tabTimelineContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Filtre özeti + aç/kapat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_background"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/tvTimelineFilterSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bu Ay · Tarih aralığı"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnToggleTimelineFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/kategori_item_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="Filtre"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Dönem + tarih satırı (kompakt) -->
            <LinearLayout
                android:id="@+id/timelineFiltersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_background"
                android:elevation="1dp"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_donem_1a"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/kategori_item_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="Bu Ay"
                        android:textColor="@color/green_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_donem_3a"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/kategori_item_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="Önceki"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_donem_6a"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/kategori_item_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="3 Ay"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_donem_tumu"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="@drawable/kategori_item_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="6 Ay+"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_baslangic_tarih"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="@drawable/tarih_chip_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="96dp"
                        android:paddingHorizontal="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="→"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_bitis_tarih"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="@drawable/tarih_chip_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="96dp"
                        android:paddingHorizontal="6dp"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Arama çubuğu -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                android:hint="İşlem ara...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTimelineSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <HorizontalScrollView
                android:id="@+id/timeline_tag_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingTop="4dp"
                android:scrollbars="none"
                android:visibility="gone">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupTimelineTags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true" />
            </HorizontalScrollView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="80dp" />

                <LinearLayout
                    android:id="@+id/timeline_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sonuç bulunamadı 🔍"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Farklı bir arama deneyin veya filtreyi temizleyin."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTimelineClearSearch"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Aramayı temizle" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/timeline_no_data_state"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bu dönemde işlem yok"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Analiz ve grafikler için önce işlem ekleyin."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTimelineGoAddTransaction"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Günlük sekmesine git" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ── TAB 3: KATEGORİ ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/tabKategoriContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Gider/Gelir toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_background"
                android:elevation="1dp"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:id="@+id/tabKatGider"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/kategori_item_selected_bg"
                    android:gravity="center"
                    android:text="💸  Gider"
                    android:textColor="@color/green_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabKatGelir"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/kategori_item_bg"
                    android:gravity="center"
                    android:text="💰  Gelir"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Grafik alanı: sağ üstte küçük toggle -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp" android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp">

                <com.example.hesapyonetimi.ui.PieChartView
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/chartTypeToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:elevation="4dp"
                    android:padding="4dp"
                    app:checkedButton="@+id/btnChartPie"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChartPie"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="Pasta"
                        android:textSize="11sp"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChartBar"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="Sütun"
                        android:textSize="11sp"
                        app:cornerRadius="10dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </FrameLayout>

            <!-- Öneri satırı -->
            <LinearLayout
                android:id="@+id/katOneriRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:visibility="gone">

                <TextView android:id="@+id/tv_oneri_emoji"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="16sp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_oneri_metin"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvKatAnaliz"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingHorizontal="8dp"
                android:paddingBottom="80dp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
