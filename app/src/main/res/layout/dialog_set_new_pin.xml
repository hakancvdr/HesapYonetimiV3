<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔑  Yeni PIN Belirle"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <View android:id="@+id/new_dot1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/new_dot2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/new_dot3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/new_dot4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
    </LinearLayout>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="0,1,2">
        <TableRow android:layout_marginBottom="8dp">
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn1" android:text="1"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn2" android:text="2"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn3" android:text="3"/>
        </TableRow>
        <TableRow android:layout_marginBottom="8dp">
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn4" android:text="4"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn5" android:text="5"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn6" android:text="6"/>
        </TableRow>
        <TableRow android:layout_marginBottom="8dp">
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn7" android:text="7"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn8" android:text="8"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn9" android:text="9"/>
        </TableRow>
        <TableRow>
            <View android:layout_width="0dp" android:layout_height="0dp"/>
            <Button style="@style/PinButtonStyle" android:id="@+id/new_btn0" android:text="0"/>
            <ImageButton
                android:id="@+id/new_btn_del"
                style="@style/PinButtonStyle"
                android:src="@android:drawable/ic_input_delete"
                app:tint="@color/ana_mavi" />
        </TableRow>
    </TableLayout>

</LinearLayout>
