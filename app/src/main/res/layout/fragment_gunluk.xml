<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:padding="20dp"
    android:background="#F4F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GÜNLÜK TAKİP"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/rg_islem_tipi"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/segmented_control_bg"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <RadioButton
            android:id="@+id/rb_gider"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:button="@null"
            android:gravity="center"
            android:text="GİDER"
            android:checked="true" />
        <RadioButton
            android:id="@+id/rb_gelir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:button="@null"
            android:gravity="center"
            android:text="GELİR" />
    </RadioGroup>

    <EditText
        android:id="@+id/et_tutar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Tutar"
        android:inputType="numberDecimal"
        android:background="@drawable/modern_edittext_bg"
        android:paddingStart="16dp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_aciklama"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Açıklama"
        android:background="@drawable/modern_edittext_bg"
        android:paddingStart="16dp"
        android:layout_marginBottom="8dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/modern_edittext_bg"
        android:layout_marginBottom="16dp">
        <AutoCompleteTextView
            android:id="@+id/auto_kategori"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="Kategori"
            android:paddingStart="16dp"
            android:focusable="false"
            android:inputType="none" />
    </FrameLayout>

    <Button
        android:id="@+id/btn_kaydet"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="KAYDET"
        android:backgroundTint="#2E7D32"
        android:textColor="@color/beyaz"
        app:cornerRadius="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_gunluk_islemler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="70dp"/>

    <ImageView
        android:id="@+id/iv_dropdown_arrow"  android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="15dp"
        android:src="@android:drawable/arrow_down_float"
        android:contentDescription="Aç"
        app:tint="#2E7D32" />

</LinearLayout>