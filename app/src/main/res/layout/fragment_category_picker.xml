<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCategoryPickerHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sık kullandıkların giriş ekranında otomatik belirir."
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/toggleCategoryType"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@drawable/toggle_pill_bg"
        android:padding="4dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/btnPickerExpense"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="💸  Gider"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:background="@drawable/toggle_pill_selected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnPickerIncome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="💰  Gelir"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryPicker"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:nestedScrollingEnabled="false" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="Kategori ekle"
        app:icon="@drawable/ic_add_modern"
        app:iconTint="@color/text_white"
        app:backgroundTint="@color/green_primary"
        android:layout_marginTop="12dp" />

</LinearLayout>

