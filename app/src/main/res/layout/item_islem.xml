<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_islem_ikon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_add" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_islem_aciklama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Market Alışverişi"
                android:textColor="@color/ana_lacivert"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_islem_kategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mutfak"
                android:textColor="@color/yazi_gri"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_islem_tutar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- ₺ 450.00"
            android:textColor="#D32F2F"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>