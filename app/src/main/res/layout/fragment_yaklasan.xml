<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/yaklasan_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hatırlatıcılar"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btn_hatirlatici_ekle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_header_card"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Özet: Toplam bekleyen + toplam tutar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bekleyen" android:textSize="11sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_bekleyen_sayi"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 adet" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Toplam tutar" android:textSize="11sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_bekleyen_toplam"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ₺" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/btn_header_card"
                android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gecikmiş" android:textSize="11sp" android:textColor="#AAFFFFFF"/>
                <TextView android:id="@+id/tv_gecikmus_sayi"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 adet" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="#FFD0D0" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Filtre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:elevation="2dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView android:id="@+id/btn_filtre_bekleyen"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:gravity="center" android:text="Bekleyen"
            android:textSize="12sp" android:textColor="@color/green_primary"
            android:background="@drawable/kategori_item_selected_bg"
            android:layout_marginEnd="4dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_filtre_gecikmus"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:gravity="center" android:text="Gecikmiş"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:background="@drawable/kategori_item_bg"
            android:layout_marginEnd="4dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_filtre_tumu"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:gravity="center" android:text="Tümü"
            android:textSize="12sp" android:textColor="@color/text_secondary"
            android:background="@drawable/kategori_item_bg"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- Liste -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Akıllı öneriler -->
                <LinearLayout
                    android:id="@+id/oneri_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <!-- Bu ay vadesi gelenler -->
                <TextView
                    android:id="@+id/tv_bu_ay_baslik"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bu ay"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_bu_ay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp"/>

                <!-- Sonraki ödemeler -->
                <TextView
                    android:id="@+id/tv_sonraki_baslik"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sonraki"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sonraki"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp"/>

                <!-- Boş durum -->
                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔔" android:textSize="48sp" android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅ Bekleyen ödemen yok"
                        android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kira, fatura gibi düzenli ödemelerinizi\nekleyerek takip edin."
                        android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:gravity="center"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="80dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
