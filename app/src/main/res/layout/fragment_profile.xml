                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textColor="@color/text_secondary" android:textSize="26sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
