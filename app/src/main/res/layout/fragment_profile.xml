<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp">

        <!-- Üst satır: başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profilim"
            android:textColor="#AACCFF"
            android:textSize="12sp"
            android:letterSpacing="0.12" />

        <!-- Avatar + isim satırı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="68dp"
                android:layout_height="68dp">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:background="@drawable/bg_profile_avatar"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/btnEditAvatar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_profile_edit_badge"
                    android:gravity="center"
                    android:text="✏"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />
            </FrameLayout>

            <!-- İsim + tarih -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kullanıcı"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnEditName"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_profile_name_edit"
                        android:gravity="center"
                        android:text="✏"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:alpha="0.85" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMemberSince"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_profile_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:text="Üye: Bu ay"
                    android:textColor="#AACCFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Stats satırı — glassmorphism panel -->
        <!-- Bu Ay Finansal Özet -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="18dp" android:orientation="vertical"
            android:background="@drawable/bg_profile_stats_panel" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bu Ay Özeti" android:textColor="#88BBFF"
                android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Gelir -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↑" android:textColor="#A5F3BB" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvMonthIncome"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₺0" android:textColor="#A5F3BB" android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gelir" android:textColor="#88BBFF" android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="44dp"
                    android:layout_gravity="center_vertical" android:background="#33FFFFFF"/>

                <!-- Gider -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↓" android:textColor="#FFAAAA" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvMonthExpense"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₺0" android:textColor="#FFAAAA" android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gider" android:textColor="#88BBFF" android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="44dp"
                    android:layout_gravity="center_vertical" android:background="#33FFFFFF"/>

                <!-- Net -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="≈" android:textColor="#FFFFFF" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvMonthNet"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₺0" android:textColor="#FFFFFF" android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Net" android:textColor="#88BBFF" android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Alt satır: işlem / kategori / üyelik -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22FFFFFF" android:layout_marginTop="12dp" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tvTotalTransactions"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:text="0 İşlem"
                    android:textColor="#BBDDFF" android:textSize="11sp"/>
                <TextView android:id="@+id/tvCategoryCount"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:text="0 Kategori"
                    android:textColor="#BBDDFF" android:textSize="11sp"/>
                <TextView android:id="@+id/tvActiveDays"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:text="Yeni"
                    android:textColor="#A5F3BB" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ══ İÇERİK ══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="16dp">

            <!-- Bölüm etiketi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="FİNANS"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold" />

            <!-- Bütçe kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- İkon -->
                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_budget"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aylık Bütçe"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvBudgetLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ayarlanmadı"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnEditBudget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_profile_action_btn"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:text="Düzenle"
                            android:textColor="@color/green_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Progress (limit varsa) -->
                    <LinearLayout
                        android:id="@+id/budgetProgressContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvBudgetUsed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Bu ay: ₺0"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvBudgetPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="%0"
                                android:textColor="@color/green_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/budgetProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:indicatorColor="#3366FF"
                            app:trackColor="#EEF2FF"
                            app:trackCornerRadius="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bölüm etiketi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:text="AYARLAR"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold" />

            <!-- Ayar kartları grubu -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Kategori Yönetimi -->
                    <LinearLayout
                        android:id="@+id/cardCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏷️"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kategori Yönetimi"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCategorySubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Kategorileri düzenle"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_secondary"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Cüzdan Yönetimi -->
                    <LinearLayout
                        android:id="@+id/cardWallets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💳"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cüzdan Yönetimi"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWalletSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Hesapları düzenle"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_secondary"
                            android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Ayraç -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp" android:background="@color/divider" />

                    <!-- Biyometrik Giriş -->
                    <LinearLayout android:id="@+id/cardBiometric"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                        <LinearLayout android:layout_width="42dp" android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="👆" android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Biyometrik Giriş" android:textColor="@color/text_primary"
                                android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvBiometricSubtitle"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="Parmak izi / yüz ile giriş"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchBiometric"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Ayraç -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp" android:background="@color/divider" />

                    <!-- PIN Değiştir -->
                    <LinearLayout android:id="@+id/cardChangePin"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                        <LinearLayout android:layout_width="42dp" android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔑" android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PIN Değiştir" android:textColor="@color/text_primary"
                                android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="Giriş PIN'ini güncelle"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Ayraç -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp" android:background="@color/divider" />

                    <!-- Güvenlik Sorusu -->
                    <LinearLayout android:id="@+id/cardSecurityQ"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                        <LinearLayout android:layout_width="42dp" android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🛡" android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Güvenlik Sorusu" android:textColor="@color/text_primary"
                                android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvSecurityQSubtitle"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="Güvenlik sorusunu değiştir"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Ayraç -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp" android:background="@color/divider" />

                    <!-- Para Birimi -->
                    <LinearLayout android:id="@+id/cardCurrency"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                        <LinearLayout android:layout_width="42dp" android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_theme" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💱" android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Para Birimi" android:textColor="@color/text_primary"
                                android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvCurrencySubtitle"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="Türk Lirası (₺)"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="26sp" />
                    </LinearLayout>

                    <!-- Ayraç -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp" android:background="@color/divider" />

                    <!-- Tema -->
                    <LinearLayout
                        android:id="@+id/cardTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_theme"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎨"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tema"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvThemeSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Sistem varsayılanı"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_secondary"
                            android:textSize="26sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Uygulama bilgisi kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_profile_icon_info"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ℹ️"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hesap Yönetimi"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Kişisel finans takip uygulaması"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAppVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_profile_version_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="v1.0"
                        android:textColor="@color/green_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Dışa Aktar / Yedek kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:id="@+id/cardExportCsv"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
                        <LinearLayout android:layout_width="42dp" android:layout_height="42dp"
                            android:background="@drawable/bg_profile_icon_category" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📤" android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Veri Dışa Aktar (CSV)" android:textColor="@color/text_primary"
                                android:textSize="14sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="Tüm işlemleri Excel/CSV olarak paylaş"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="26sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
