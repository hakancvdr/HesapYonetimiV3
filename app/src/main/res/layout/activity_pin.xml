<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/arka_plan"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/home_24px"
        app:tint="@color/ana_mavi" />

    <TextView
        android:id="@+id/tv_pin_baslik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Güvenli Giriş"
        android:textColor="@color/yazi_koyu"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Lütfen 4 haneli PIN kodunuzu girin"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="50dp"
        android:orientation="horizontal">
        <View android:id="@+id/dot1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/dot2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/dot3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
        <View android:id="@+id/dot4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="10dp" android:background="@drawable/pin_dot_off"/>
    </LinearLayout>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="0,1,2">
        <TableRow android:layout_marginBottom="12dp">
            <Button style="@style/PinButtonStyle" android:text="1" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="2" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="3" android:onClick="onNumberClick"/>
        </TableRow>
        <TableRow android:layout_marginBottom="12dp">
            <Button style="@style/PinButtonStyle" android:text="4" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="5" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="6" android:onClick="onNumberClick"/>
        </TableRow>
        <TableRow android:layout_marginBottom="12dp">
            <Button style="@style/PinButtonStyle" android:text="7" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="8" android:onClick="onNumberClick"/>
            <Button style="@style/PinButtonStyle" android:text="9" android:onClick="onNumberClick"/>
        </TableRow>
        <TableRow>
            <View android:layout_width="0dp" android:layout_height="0dp"/>
            <Button style="@style/PinButtonStyle" android:text="0" android:onClick="onNumberClick"/>
            <ImageButton
                android:id="@+id/btn_delete"
                style="@style/PinButtonStyle"
                android:src="@android:drawable/ic_input_delete"
                app:tint="@color/ana_mavi"
                android:onClick="onDeleteClick" />
        </TableRow>
    </TableLayout>

    <!-- PIN sıfırlama bağlantısı -->
    <TextView
        android:id="@+id/tv_forgot_pin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Şifremi Unuttum"
        android:textColor="@color/green_light"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
