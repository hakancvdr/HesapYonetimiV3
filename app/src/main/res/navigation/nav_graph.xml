<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_ozet">

    <fragment
        android:id="@+id/nav_ozet"
        android:name="com.example.hesapyonetimi.DashboardFragment"
        android:label="@string/nav_home_short" />

    <fragment
        android:id="@+id/nav_gunluk"
        android:name="com.example.hesapyonetimi.GunlukFragment"
        android:label="@string/nav_gunluk_short" />

    <fragment
        android:id="@+id/nav_aylik"
        android:name="com.example.hesapyonetimi.AylikFragment"
        android:label="@string/nav_monthly_short">
        <action
            android:id="@+id/action_aylik_to_kategoriDetay"
            app:destination="@id/kategoriDetayFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/nav_plan"
        android:name="com.example.hesapyonetimi.PlanFragment"
        android:label="@string/nav_plan_short">
        <argument
            android:name="initialTab"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/nav_security"
        android:name="com.example.hesapyonetimi.presentation.profile.SecurityPrivacyFragment"
        android:label="@string/security_privacy_title" />

    <fragment
        android:id="@+id/nav_profil"
        android:name="com.example.hesapyonetimi.ProfileFragment"
        android:label="Profil">
        <argument
            android:name="openBudgetDialog"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_profil_to_wallet"
            app:destination="@id/walletFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_profil"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_profil_to_pro"
            app:destination="@id/proFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_profil"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/kategoriDetayFragment"
        android:name="com.example.hesapyonetimi.presentation.aylik.KategoriDetayFragment"
        android:label="Kategori Detay">
        <argument
            android:name="kat"
            app:argType="com.example.hesapyonetimi.presentation.aylik.KategoriOzet" />
        <argument
            android:name="ayOffset"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/walletFragment"
        android:name="com.example.hesapyonetimi.presentation.wallet.WalletFragment"
        android:label="Cüzdanlar" />

    <fragment
        android:id="@+id/proFragment"
        android:name="com.example.hesapyonetimi.presentation.pro.ProFragment"
        android:label="PRO" />

    <fragment
        android:id="@+id/categoryPickerFragment"
        android:name="com.example.hesapyonetimi.presentation.categories.CategoryPickerFragment"
        android:label="Kategoriler" />

    <fragment
        android:id="@+id/themeLanguageFragment"
        android:name="com.example.hesapyonetimi.presentation.settings.ThemeLanguageFragment"
        android:label="@string/drawer_menu_theme_language" />

    <fragment
        android:id="@+id/helpPlaceholderFragment"
        android:name="com.example.hesapyonetimi.presentation.settings.HelpPlaceholderFragment"
        android:label="@string/drawer_menu_help" />

    <fragment
        android:id="@+id/contactPlaceholderFragment"
        android:name="com.example.hesapyonetimi.presentation.settings.ContactPlaceholderFragment"
        android:label="@string/drawer_menu_contact" />

</navigation>
