<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.HesapYonetimi" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">#2C3E8C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="materialAlertDialogTheme">@style/App.MaterialAlertDialog</item>
        <item name="bottomSheetDialogTheme">@style/App.BottomSheetDialog</item>
    </style>

    <style name="Theme.HesapYonetimi" parent="Base.Theme.HesapYonetimi" />

    <style name="TextAppearance.App.NavigationDrawer" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.App.NavigationDrawer.Subheader" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="ThemeOverlay.App.NavigationDrawer" parent="ThemeOverlay.Material3.NavigationView">
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorControlNormal">@color/green_primary</item>
        <item name="itemBackground">@drawable/drawer_item_background</item>
        <item name="subheaderTextAppearance">@style/TextAppearance.App.NavigationDrawer.Subheader</item>
        <item name="subheaderColor">@color/text_secondary</item>
    </style>

    <style name="Widget.App.DrawerFooterButton" parent="Widget.Material3.Button">
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.App.DrawerFooterButton.Primary" parent="Widget.App.DrawerFooterButton">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.App.DrawerFooterButton.Outline" parent="Widget.App.DrawerFooterButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">15dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <!-- MaterialAlertDialog — yumuşatılmış köşeler -->
    <style name="App.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.AlertDialog</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>
    <style name="ShapeAppearance.App.AlertDialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- BottomSheetDialog — night mod ile uyumlu olmalı -->
    <style name="App.BottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/App.BottomSheet</item>
        <item name="android:backgroundDimAmount">0.45</item>
    </style>
    <style name="App.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/ShapeAppearance.App.BottomSheet</item>
        <item name="android:backgroundTint">@color/card_background</item>
    </style>
    <style name="ShapeAppearance.App.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="PinButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">75dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/ana_mavi</item>
        <item name="android:backgroundTint">@color/kart_beyaz</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MaterialComponents.MediumComponent</item>
    </style>
</resources>
