<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.HesapYonetimi" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">#2C3E8C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.HesapYonetimi" parent="Base.Theme.HesapYonetimi" />

